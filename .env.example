# =============================================================================
# Frontend Environment Variables for Railway Deployment
# =============================================================================
# Copy this to .env for local development, or set these in Railway Variables

# -----------------------------------------------------------------------------
# App URLs
# -----------------------------------------------------------------------------
BASEPATH=
# Local dev: use the frontend port currently in use (for example http://localhost:3001)
NEXT_PUBLIC_APP_URL=https://invoice-frontend-app-production.up.railway.app
NEXT_PUBLIC_BACKEND_URL=https://your-backend.up.railway.app

# -----------------------------------------------------------------------------
# Authentication (NextAuth.js)
# -----------------------------------------------------------------------------
NEXTAUTH_BASEPATH=/api/auth
NEXTAUTH_URL=${NEXT_PUBLIC_APP_URL}/api/auth
NEXTAUTH_SECRET=generate-a-strong-secret-here

# Optional: Google OAuth
# Add both local callback URLs (3000-3003) and the Railway URL in Google Console
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# AI Forecasting (server-side only, never expose to client)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_FORECAST_MODEL=gpt-5.2
OPENAI_API_BASE=https://api.openai.com/v1

# -----------------------------------------------------------------------------
# Node
# -----------------------------------------------------------------------------
NODE_ENV=production
